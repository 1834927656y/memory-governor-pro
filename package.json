{
  "name": "memory-lancedb-pro",
  "version": "1.1.0-beta.10",
  "description": "OpenClaw enhanced LanceDB memory plugin with hybrid retrieval (Vector + BM25), cross-encoder rerank, multi-scope isolation, long-context chunking, and management CLI",
  "type": "module",
  "main": "index.ts",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "lancedb",
    "vector-search",
    "bm25",
    "hybrid-retrieval",
    "rerank",
    "ai-memory",
    "long-term-memory",
    "chunking",
    "long-context"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CortexReach/memory-lancedb-pro.git"
  },
  "author": "win4r",
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@sinclair/typebox": "0.34.48",
    "apache-arrow": "18.1.0",
    "json5": "^2.2.3",
    "openai": "^6.21.0",
    "proper-lockfile": "^4.1.2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "governor:daily-rotate": "node --import jiti/register src/index.ts daily-rotate",
    "governor:daily-rotate:all-agents": "node --import jiti/register src/index.ts daily-rotate --all-agents",
    "governor:nightly": "node --import jiti/register src/index.ts nightly",
    "governor:bootstrap": "node --import jiti/register src/index.ts bootstrap --days 90 --allowDelete",
    "governor:flush": "node --import jiti/register src/index.ts flush --percent 70",
    "governor:governance": "node --import jiti/register src/index.ts governance",
    "governor:audit-inspect": "node --import jiti/register src/index.ts audit-inspect",
    "governor:audit-restore": "node --import jiti/register src/index.ts audit-restore-sessions",
    "governor:audit-clear-rotation": "node --import jiti/register src/index.ts audit-clear-rotation",
    "governor:audit-purge-memories": "node --import jiti/register src/index.ts audit-purge-memories",
    "governor:rollback-first-install": "node --import jiti/register src/index.ts rollback-first-install-backfill",
    "governor:rollback-all-refined": "node --import jiti/register src/index.ts rollback-all-refined",
    "governor:purge-refine-artifact-dirs": "node --import jiti/register src/index.ts purge-refine-artifact-dirs",
    "governor:archive-prune": "node --import jiti/register src/index.ts archive-prune",
    "governor:verify-layered-injection": "node scripts/verify-layered-injection.mjs",
    "governor:test-full-strip": "node --import jiti/register scripts/test-governor-full-strip.ts",
    "governor:sync-plugin-load-paths": "node scripts/sync-plugin-load-paths.mjs",
    "governor:plugin:install": "node scripts/manage-plugin-install.mjs install",
    "governor:plugin:uninstall": "node scripts/manage-plugin-install.mjs uninstall",
    "governor:vendor:init-self-improving": "node --import jiti/register src/index.ts vendor:init-self-improving",
    "version": "node scripts/sync-plugin-version.mjs openclaw.plugin.json package.json && git add openclaw.plugin.json"
  },
  "devDependencies": {
    "commander": "^14.0.0",
    "jiti": "^2.6.0",
    "typescript": "^5.9.3"
  }
}
